  try {
    if (!urlList) {
      BYLog.debug('reportAdnLoaded null')
      return
    }

    BYLog.debug(`е№ҝе‘ҠеҗҜеҠЁдёҠжҠҘеҸ‘иө·`)

    for (let index = 0; index < urlList.length; index++) {
